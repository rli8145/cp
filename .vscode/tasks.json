{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "mkdir -p ${fileDirname}/build && /opt/homebrew/bin/g++-15 -std=c++20 -O2 -Wall -Wextra ${file} -o ${fileDirname}/build/${fileBasenameNoExtension}",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build (debug)",
            "type": "shell",
            "command": "mkdir -p ${fileDirname}/build && /opt/homebrew/bin/g++-15 -std=c++20 -O0 -g -Wall -Wextra -D_GLIBCXX_DEBUG ${file} -o ${fileDirname}/build/${fileBasenameNoExtension}_dbg",
            "group": "build"
        }
    ]
}