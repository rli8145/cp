{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "clang++ -std=c++20 -O2 -Wall ${file} -o ${fileDirname}/build/${fileBasenameNoExtension}",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build (debug)",
            "type": "shell",
            "command": "g++ -std=c++20 -O0 -g -Wall -Wextra -fsanitize=undefined,address -D_GLIBCXX_DEBUG ${file} -o ${fileBasenameNoExtension}_dbg",
            "group": "build"
        }
    ]
}